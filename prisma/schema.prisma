// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  plexId       String        @unique // The unique ID from Plex
  username     String
  avatarUrl    String?
  plexToken    String?
  isAdmin      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  flagRequests FlagRequest[]
}

model MediaItem {
  id           String        @id @default(cuid())
  plexRatingKey String       @unique // The unique ID of the media item in Plex
  title        String
  type         String        // "movie", "show", "season"
  seasonNumber Int?          // Only populated if type is "season"
  thumbUrl     String?       // URL to the poster/thumbnail from Plex
  fileSize     BigInt?       // Size in bytes (optional, fetched asynchronously)
  addedAt      DateTime?     // When it was added to the server
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  flagRequests FlagRequest[]
}

model FlagRequest {
  id           String    @id @default(cuid())
  userId       String
  mediaItemId  String
  status       String    @default("pending") // "pending", "approved", "kept"
  adminNote    String?   // Optional note provided by the admin when status is changed
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem    MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId]) // A user can only flag a specific item once (unless it's deleted)
}
